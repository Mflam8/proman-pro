{
  "name": "ConversationAnalysis",
  "type": "object",
  "properties": {
    "customer_id": {
      "type": "string",
      "description": "ID del cliente asociado"
    },
    "inquiry_id": {
      "type": "string",
      "description": "ID del trabajo asociado si existe"
    },
    "conversation_id": {
      "type": "string",
      "description": "ID de la conversaci\u00f3n de WhatsApp"
    },
    "phone": {
      "type": "string",
      "description": "Tel\u00e9fono del contacto"
    },
    "summary": {
      "type": "string",
      "description": "Resumen generado por IA"
    },
    "intent": {
      "type": "string",
      "description": "Intenci\u00f3n principal detectada"
    },
    "service": {
      "type": "string",
      "description": "Servicio detectado"
    },
    "urgency": {
      "type": "string",
      "enum": [
        "baja",
        "media",
        "alta",
        "urgente"
      ],
      "default": "media",
      "description": "Urgencia detectada"
    },
    "direction_or_location": {
      "type": "string",
      "description": "Direcci\u00f3n o zona detectada"
    },
    "detected_name": {
      "type": "string",
      "description": "Nombre principal detectado por IA"
    },
    "detected_address": {
      "type": "string",
      "description": "Direcci\u00f3n estructurada o principal detectada"
    },
    "detected_price": {
      "type": "number",
      "description": "Monto detectado por IA"
    },
    "detected_schedule": {
      "type": "string",
      "description": "Fecha u hora principal detectada"
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Campos faltantes detectados para operar el caso"
    },
    "field_confidence_json": {
      "type": "string",
      "description": "JSON serializado con confianza por campo detectado"
    },
    "field_evidence_json": {
      "type": "string",
      "description": "JSON serializado con evidencia por campo detectado"
    },
    "names": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Nombres detectados"
    },
    "dates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Fechas u horarios detectados"
    },
    "payments": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Pagos o montos detectados"
    },
    "suggested_action": {
      "type": "string",
      "enum": [
        "crear_inquiry",
        "vincular_job",
        "actualizar_estado",
        "marcar_urgente",
        "ignorar",
        "dar_seguimiento"
      ],
      "description": "Acci\u00f3n sugerida por IA"
    },
    "next_best_action": {
      "type": "string",
      "description": "Siguiente mejor acci\u00f3n sugerida por IA"
    },
    "suggested_next_reply": {
      "type": "string",
      "description": "Respuesta sugerida al cliente"
    },
    "requires_human_review": {
      "type": "boolean",
      "default": false,
      "description": "Si requiere revisi\u00f3n humana"
    },
    "human_review_status": {
      "type": "string",
      "enum": [
        "pending_review",
        "approved",
        "rejected",
        "ignored"
      ],
      "default": "pending_review",
      "description": "Estado de revisi\u00f3n humana"
    },
    "approved_operational_snapshot": {
      "type": "string",
      "description": "JSON serializado del snapshot aprobado manualmente"
    },
    "ai_confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confianza del an\u00e1lisis IA"
    },
    "operational_risk": {
      "type": "string",
      "enum": [
        "bajo",
        "medio",
        "alto",
        "critico"
      ],
      "description": "Riesgo operativo detectado"
    },
    "escalation_needed": {
      "type": "boolean",
      "default": false,
      "description": "Si necesita escalamiento"
    },
    "unread_customer_message": {
      "type": "boolean",
      "default": false,
      "description": "Si hay mensaje del cliente pendiente de atender"
    },
    "pending_customer_response": {
      "type": "boolean",
      "default": false,
      "description": "Si se espera respuesta del cliente"
    },
    "risks_detected": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Riesgos detectados"
    },
    "pending_from_customer": {
      "type": "string",
      "description": "Qu\u00e9 hace falta del cliente"
    },
    "sla_warning": {
      "type": "boolean",
      "default": false,
      "description": "Si existe alerta de SLA"
    },
    "previous_analysis_summary": {
      "type": "string",
      "description": "Resumen previo usado como contexto"
    },
    "analyzed_messages_count": {
      "type": "number",
      "description": "Cantidad de mensajes analizados"
    },
    "trigger_reason": {
      "type": "string",
      "description": "Motivo que dispar\u00f3 el an\u00e1lisis"
    },
    "ai_prompt_version": {
      "type": "string",
      "description": "Versi\u00f3n del prompt utilizado"
    },
    "analysis_model": {
      "type": "string",
      "description": "Modelo usado en el an\u00e1lisis"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confianza general reportada"
    },
    "token_usage": {
      "type": "number",
      "description": "Uso estimado de tokens"
    },
    "analysis_duration_ms": {
      "type": "number",
      "description": "Duraci\u00f3n del an\u00e1lisis en milisegundos"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "reviewed",
        "ignored",
        "applied"
      ],
      "default": "pending",
      "description": "Estado de revisi\u00f3n administrativa"
    },
    "raw_analysis": {
      "type": "string",
      "description": "Resultado completo en JSON serializado"
    }
  },
  "required": [
    "summary",
    "intent",
    "suggested_action"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "employee_type": "Supervisor"
          }
        },
        {
          "user_condition": {
            "role": "system"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "employee_type": "Supervisor"
          }
        },
        {
          "data.customer_id": {
            "$in": {
              "query": "Customer",
              "field": "id",
              "filter": {
                "data.commercial_owner": "{{user.email}}"
              }
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "employee_type": "Supervisor"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}